# Application
APP_NAME="SinarSteel"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database PostgreSQL
DATABASE_URL=postgresql+asyncpg://steelmaster:steelmaster@localhost:5432/sinarsteel

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (ubah sesuai domain frontend Electron saat production, untuk dev biarkan localhost)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Storage (untuk upload foto absensi, bukti COD, dll)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes